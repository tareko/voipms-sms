# --- Server ---
PORT=8317

# --- voip.ms API (https://voip.ms/m/api.php) ---
# Your voip.ms login email and a dedicated API password (NOT your portal password).
VOIPMS_API_USERNAME=
VOIPMS_API_PASSWORD=
# ISO country code used to normalize local numbers without a country code.
VOIPMS_DEFAULT_COUNTRY=US
# Optional: restrict/order DIDs shown (comma-separated). Empty = all SMS-capable DIDs.
VOIPMS_DIDS=
# Polling interval (ms). 20000 = responsive for MVP; raise to ~120000 once webhook is live.
VOIPMS_POLL_INTERVAL_MS=20000

# --- Nextcloud CardDAV (contacts) ---
NEXTCLOUD_URL=https://cloud.glia.org
NEXTCLOUD_USERNAME=
# Use a Nextcloud App Password, NOT your main account password.
NEXTCLOUD_PASSWORD=
NEXTCLOUD_ADDRESSBOOK=
# How often to refresh contacts (ms). 1800000 = 30 min.
CONTACTS_SYNC_INTERVAL_MS=1800000

# --- Inbound webhook (Milestone 2) ---
# Random secret appended to the voip.ms callback URL as ?key=. Generate with:
#   openssl rand -hex 32
WEBHOOK_KEY=
# Public URL the voip.ms callback points at (e.g. https://sms.example.com). Shown in the UI.
PUBLIC_WEBHOOK_URL=

# --- Push (ntfy / UnifiedPush) ---
# Self-hosted ntfy server URL (e.g. http://192.168.1.12:8090), shared topic, and
# optional publish token. Leave blank to disable push.
NTFY_URL=
NTFY_TOPIC=
NTFY_TOKEN=

# --- App auth (optional) ---
# If set, all /api routes require `Authorization: Bearer <token>`. If blank
# (default), the backend is open and relies on the network (e.g. VPN) for access.
APP_API_TOKEN=

# --- Storage ---
DB_PATH=./data/app.db
