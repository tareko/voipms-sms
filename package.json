{
  "name": "voipms-sms",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm -w server run dev",
    "dev:web": "npm -w web run dev",
    "start": "npm -w server run start",
    "build:web": "npm -w web run build",
    "typecheck": "npm -w server run typecheck && npm -w web run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
